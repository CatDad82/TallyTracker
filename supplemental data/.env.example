# Copy this file to .env and fill in your values.
# The app reads these on startup if present.

# Your Monday.com personal API token (v2)
# Found at: monday.com → Profile → Developers → API v2 Token
MONDAY_API_TOKEN=""

# ID of the Monday board where daily reviews are posted
# Found in the board URL: monday.com/boards/<BOARD_ID>
MONDAY_REVIEW_BOARD_ID=""
