{
  "manifest_version": 3,
  "name": "Tally Time Tracker",
  "version": "1.2.4",
  "description": "Links Monday.com tasks to your active Tally time entry automatically.",
  "permissions": ["tabs"],
  "host_permissions": [
    "*://*.monday.com/*",
    "http://127.0.0.1:5610/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.monday.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
